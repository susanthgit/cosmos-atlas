---
import '../styles/atmosphere.css';
import '../styles/cosmos.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Cosmos Atlas — A Guide to Cloud',
  description = 'A living solar system mapping the A Guide to Cloud cosmos. Earth, CMD, Shift, Plain AI, Agentic, Claw — and the moons that orbit them. Click a planet to learn what it is.',
  canonical = 'https://cosmos.aguidetocloud.com/',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#02030E">
  <meta name="color-scheme" content="dark">

  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap">

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate icon" type="image/png" href="/favicon-32.png">

  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content="https://cosmos.aguidetocloud.com/og.png">
  <meta property="og:site_name" content="Cosmos Atlas">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://cosmos.aguidetocloud.com/og.png">

  <meta name="robots" content="index, follow">
  <meta name="author" content="Susanth Sutheesh (Sush)">

  <slot name="head" />
</head>
<body>
  <a href="#static-shell" class="skip-link">Skip to planet list</a>
  <slot />
</body>
</html>

<script is:inline>
  // Flag early so the static fallback can hide before paint when JS is on
  document.documentElement.classList.add('js-ready');
</script>

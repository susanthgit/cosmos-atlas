---
import '../styles/atmosphere.css';
import '../styles/cosmos.css';
// V3 polish #9 — variable fonts. One file per family covers every weight, so
// we no longer ship six separate latin-{400,500,600,700}.css static slices.
// V3 polish #5 — Caveat. Used for founder notes only (.card-founder etc).
import '@fontsource-variable/space-grotesk';
import '@fontsource-variable/jetbrains-mono';
import '@fontsource/caveat/latin-400.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = 'Cosmos Atlas — A Guide to Cloud',
  description = 'A living solar system mapping the A Guide to Cloud cosmos. Earth, CMD, Shift, Plain AI, Agentic, Claw — and the moons that orbit them. Click a planet to learn what it is.',
  canonical = 'https://cosmos.aguidetocloud.com/',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#02030E">
  <meta name="color-scheme" content="dark">

  <title>{title}</title>
  <meta name="description" content={description}>
  <link rel="canonical" href={canonical}>

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">

  <!-- 10 May 2026 — universal cosmos-bar. Loaded on every planet across the
       universe; the atlas hosts the source-of-truth files locally. The bar's
       placeholder CSS also provides the --cosmos-bar-h variable that .cosmos
       uses to leave room at the top. -->
  <link rel="stylesheet" href="/cosmos-bar.css">

  <meta property="og:type" content="website">
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content="https://cosmos.aguidetocloud.com/og.png">
  <meta property="og:site_name" content="Cosmos Atlas">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://cosmos.aguidetocloud.com/og.png">

  <meta name="robots" content="index, follow">
  <meta name="author" content="Susanth Sutheesh (Sush)">

  <slot name="head" />

  <!-- V3.x — Cloudflare Web Analytics (privacy-first, no cookies, no PII).
       The token below is a public site identifier, not a secret. CF dashboard
       didn't auto-install for this subdomain so the snippet lives here. -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "7c11668cc9e544f2baf2c3d9d7eb2750"}'></script>
</head>
<body>
  <a href="#static-shell" class="skip-link">Skip to planet list</a>

  <!-- 10 May 2026 — Universal cosmos-bar leads every page in the universe.
       active="cosmos" dims the cosmos slot (you-are-here). data-host="self"
       makes it fetch atlas-bar.json from the current origin so localhost dev
       and the production cosmos host both work. -->
  <cosmos-bar data-host="self" active="cosmos"></cosmos-bar>

  <slot />

  <script async src="/cosmos-bar.js"></script>
</body>
</html>

<script is:inline>
  document.documentElement.classList.add('js-ready');
</script>

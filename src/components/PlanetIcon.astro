---
/**
 * PlanetIcon — atlas-vendored canonical 7-icon contract from cosmos rail
 * (mirrors aguidetocloud-revamp/layouts/partials/planet-icon.html and siblings).
 * Adds curriculum (Plain AI moon) and mcp (the star).
 *
 * IconSlug ⊇ planets.json slugs:
 *   earth · guided · brainbar · shift · plainai · agentic · claw · curriculum · mcp
 */
interface Props {
  slug: 'earth' | 'guided' | 'brainbar' | 'shift' | 'plainai' | 'agentic' | 'claw' | 'curriculum' | 'mcp' | 'youtube' | 'bites' | 'linkedin' | 'kofi-shop' | 'kofi-tip';
  size?: number;
  scope?: string;
}
const { slug, size = 32, scope = 'atlas' } = Astro.props;
const gradId = `pa-${scope}-${slug}-grad`;
const maskId = `pa-${scope}-${slug}-mask`;
---

{slug === 'earth' && (
  /* V3 polish #8 — AVIF lotus with WebP fallback. ~30% smaller, identical visual. */
  <picture>
    <source srcset="/planets/earth-lotus.avif" type="image/avif" />
    <img
      src="/planets/earth-lotus.webp"
      width={size}
      height={size}
      alt=""
      loading="eager"
      decoding="async"
      style={`width:${size}px;height:${size}px;object-fit:contain;display:block`}
    />
  </picture>
)}

{slug === 'guided' && (
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <mask id={maskId}>
      <rect width="32" height="32" fill="white"/>
      <circle cx="20" cy="13" r="11" fill="black"/>
    </mask>
    <circle cx="16" cy="16" r="13" fill="#E0D7BE" mask={`url(#${maskId})`}/>
  </svg>
)}

{slug === 'brainbar' && (
  <svg viewBox="0 0 24 24" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <text x="6" y="16" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13" font-weight="700" fill="#86EFAC">$</text>
    <line x1="14" y1="14" x2="20" y2="14" stroke="#86EFAC" stroke-width="2.2" stroke-linecap="round">
      <animate attributeName="opacity" values="1;0" keyTimes="0;0.5" dur="1.2s" repeatCount="indefinite" calcMode="discrete"/>
    </line>
  </svg>
)}

{slug === 'shift' && (
  <svg viewBox="0 0 60 60" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <circle cx="30" cy="30" r="27" fill="none" stroke="#FDBA74" stroke-width="2.5"/>
    <circle cx="30" cy="30" r="22" fill="none" stroke="#FDBA74" stroke-width="1" opacity=".55"/>
    <path d="M 30 30 L 42.6 11.6 A 22 22 0 0 1 52 30 Z" fill="#E25822" opacity=".28">
      <animate attributeName="opacity" values=".18;.32;.18" dur="3s" repeatCount="indefinite"/>
    </path>
    <line x1="30" y1="30" x2="46" y2="14" stroke="#E25822" stroke-width="2.6" stroke-linecap="round">
      <animateTransform attributeName="transform" type="rotate" values="-3 30 30;3 30 30;-3 30 30" dur="4s" repeatCount="indefinite"/>
    </line>
    <circle cx="30" cy="30" r="3.2" fill="#FDBA74"/>
  </svg>
)}

{slug === 'plainai' && (
  <svg viewBox="0 0 38 30" width={size * 1.27} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#67E8F9"/>
        <stop offset="50%" stop-color="#A78BFA"/>
        <stop offset="100%" stop-color="#F472B6"/>
      </linearGradient>
    </defs>
    <path d="M4 3 a3 3 0 0 1 3-3 h24 a3 3 0 0 1 3 3 v15 a3 3 0 0 1 -3 3 h-15 l-6 5 v-5 h-3 a3 3 0 0 1 -3 -3 z"
          fill={`url(#${gradId})`}/>
    <text x="19" y="11.5" text-anchor="middle" dominant-baseline="middle"
          font-family="Inter, system-ui, sans-serif" font-size="11" font-weight="800"
          fill="white" letter-spacing="-0.04em">AI</text>
  </svg>
)}

{slug === 'curriculum' && (
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#BBF7D0"/>
        <stop offset="100%" stop-color="#22C55E"/>
      </linearGradient>
    </defs>
    <path d="M16 28 V14" stroke="#86EFAC" stroke-width="1.8" stroke-linecap="round" fill="none"/>
    <path d="M16 18 C12 18 8 16 7 12 C12 12 16 14 16 18 Z" fill={`url(#${gradId})`}/>
    <path d="M16 16 C20 16 24 14 25 10 C20 10 16 12 16 16 Z" fill={`url(#${gradId})`}/>
    <circle cx="16" cy="14" r="1.4" fill="#16A34A"/>
  </svg>
)}

{slug === 'agentic' && (
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <circle cx="16" cy="16" r="11" fill="#0EA5E9" opacity="0.12"/>
    <circle cx="16" cy="16" r="7" fill="#0EA5E9" opacity="0.22"/>
    <circle cx="16" cy="16" r="4" fill="#7DD3FC">
      <animate attributeName="opacity" values="1;0.55;1" dur="2.4s" repeatCount="indefinite"/>
    </circle>
    <circle cx="16" cy="16" r="1.6" fill="#F2EDE3"/>
  </svg>
)}

{slug === 'claw' && (
  <svg viewBox="0 0 24 24" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path d="M7 4 L4 4 L4 20 L7 20" stroke="#F2EDE3" stroke-width="2.2" fill="none" stroke-linecap="round"/>
    <path d="M17 4 L20 4 L20 20 L17 20" stroke="#F2EDE3" stroke-width="2.2" fill="none" stroke-linecap="round"/>
    <g stroke="#FF2626" stroke-width="2" stroke-linecap="round" fill="none">
      <line x1="12" y1="8" x2="12" y2="16"/>
      <line x1="8.5" y1="9.5" x2="15.5" y2="14.5"/>
      <line x1="15.5" y1="9.5" x2="8.5" y2="14.5"/>
    </g>
  </svg>
)}

{slug === 'mcp' && (
  /* V3.5 — MCP reimagined as a satellite DISH (the relay), not a star.
     Honest data flow: planets publish → dish ingests → outside agents query.
     Distinct from long-form/bites satellites (which have solar panels + branded
     bodies). This is a parabolic dish + support strut + soft signal pulse. */
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Outer warm halo so the dish sits on dark canvas */}
    <ellipse cx="16" cy="17" rx="14" ry="11" fill="#FFB347" opacity="0.14">
      <animate attributeName="opacity" values="0.10;0.20;0.10" dur="3.4s" repeatCount="indefinite"/>
    </ellipse>

    {/* Tripod base struts — three short legs anchoring the strut */}
    <g stroke="#A39B8A" stroke-width="0.9" stroke-linecap="round">
      <line x1="13" y1="28" x2="16" y2="22"/>
      <line x1="19" y1="28" x2="16" y2="22"/>
      <line x1="16" y1="28" x2="16" y2="22"/>
    </g>

    {/* Vertical support strut from base to dish */}
    <line x1="16" y1="22" x2="16" y2="14" stroke="#C9C2B4" stroke-width="1.1" stroke-linecap="round"/>

    {/* Parabolic dish — opens upward and slightly toward viewer.
        Path: shallow parabola, gold rim with darker interior so it reads as a bowl. */}
    <path
      d="M 4 12 Q 16 -2 28 12 L 25 14 Q 16 6 7 14 Z"
      fill="#FFD89A"
      stroke="#FFB347"
      stroke-width="0.9"
      stroke-linejoin="round"
    >
      <animate attributeName="opacity" values="0.92;1;0.92" dur="2.6s" repeatCount="indefinite"/>
    </path>

    {/* Inner dish shadow — gives the bowl depth */}
    <path
      d="M 7 14 Q 16 6 25 14 L 23 14.6 Q 16 8.5 9 14.6 Z"
      fill="#7A4A1A"
      opacity="0.35"
    />

    {/* Receiver feed at focal point — small bright dot on a thin support */}
    <line x1="16" y1="13.5" x2="16" y2="9" stroke="#FFB347" stroke-width="0.7" stroke-linecap="round"/>
    <circle cx="16" cy="9" r="1.3" fill="#FFFFFF" opacity="0.95">
      <animate attributeName="r" values="1.0;1.6;1.0" dur="1.8s" repeatCount="indefinite"/>
    </circle>

    {/* Soft signal arcs above the dish — three concentric arcs that pulse, the
        "listening / collecting" signal coming in from above */}
    <g fill="none" stroke="#FFE9C4" stroke-linecap="round" opacity="0.7">
      <path d="M 11 6 Q 16 2 21 6" stroke-width="0.7">
        <animate attributeName="opacity" values="0.2;0.85;0.2" dur="2.2s" repeatCount="indefinite"/>
      </path>
      <path d="M 9 4 Q 16 -1 23 4" stroke-width="0.6">
        <animate attributeName="opacity" values="0.85;0.2;0.85" dur="2.2s" repeatCount="indefinite"/>
      </path>
      <path d="M 7 2 Q 16 -3 25 2" stroke-width="0.5">
        <animate attributeName="opacity" values="0.2;0.85;0.2" dur="2.2s" begin="0.7s" repeatCount="indefinite"/>
      </path>
    </g>
  </svg>
)}

{slug === 'youtube' && (
  /* Phase B-2 — YouTube unified satellite. Replaces long-form + bites split.
     Same satellite vocabulary as the old long-form (panels + antenna + flare)
     but with a slight "two-format" hint: a small vertical bar inside the
     central rounded body suggesting both 16:9 and 9:16 in the same frame.
     One body, two CTAs (long-form on susanthsutheesh + shorts on
     aguidetocloud) — the card carries the split. */
  <svg viewBox="0 0 38 34" width={size * 1.12} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Soft outer warmth so the body has presence on dark canvas */}
    <ellipse cx="19" cy="17" rx="18" ry="10" fill="#7F1D1D" opacity="0.18"/>

    {/* Whole satellite gently wobbles — feels alive, like an in-orbit course correction */}
    <g>
      <animateTransform attributeName="transform" type="rotate"
                        values="-1.4 19 17; 1.4 19 17; -1.4 19 17"
                        dur="4.6s" repeatCount="indefinite"/>

      {/* RF wave halo — three concentric arcs above the antenna, soft pulse */}
      <g fill="none" stroke="#FCA5A5" stroke-linecap="round" opacity="0.6">
        <path d="M 14 5 Q 19 1 24 5" stroke-width="0.6">
          <animate attributeName="opacity" values="0.2;0.85;0.2" dur="2.4s" repeatCount="indefinite"/>
        </path>
        <path d="M 12 3 Q 19 -2 26 3" stroke-width="0.5">
          <animate attributeName="opacity" values="0.85;0.2;0.85" dur="2.4s" repeatCount="indefinite"/>
        </path>
      </g>

      {/* LEFT solar panel — blue gridded rectangle, struts to body */}
      <g>
        <rect x="1" y="14" width="9" height="6" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
        <line x1="4" y1="14" x2="4" y2="20" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="7" y1="14" x2="7" y2="20" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="1" y1="17" x2="10" y2="17" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="10" y1="17" x2="13" y2="17" stroke="#94A3B8" stroke-width="0.6"/>
      </g>

      {/* RIGHT solar panel — mirrored */}
      <g>
        <rect x="28" y="14" width="9" height="6" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
        <line x1="31" y1="14" x2="31" y2="20" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="34" y1="14" x2="34" y2="20" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="28" y1="17" x2="37" y2="17" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="25" y1="17" x2="28" y2="17" stroke="#94A3B8" stroke-width="0.6"/>
      </g>

      {/* Antenna — short whisker with blinking transmitter dot */}
      <line x1="19" y1="12" x2="19" y2="7" stroke="#94A3B8" stroke-width="0.7"/>
      <circle cx="19" cy="6.5" r="0.9" fill="#FCA5A5">
        <animate attributeName="opacity" values="0.4;1;0.4" dur="1.6s" repeatCount="indefinite"/>
      </circle>

      {/* Central satellite body — YouTube red rounded rect with play triangle */}
      <rect x="14" y="12" width="10" height="10" rx="1.6" ry="1.6" fill="#DC2626" stroke="#FCA5A5" stroke-width="0.4">
        <animate attributeName="opacity" values="0.92;1;0.92" dur="2.4s" repeatCount="indefinite"/>
      </rect>
      <polygon points="16.6,14.5 16.6,19.5 21.4,17" fill="#FFFFFF"/>

      {/* REC indicator — small red blinking dot in the upper-left of the body
          (broadcasting LIVE feel — funny because it's an old-school recording light) */}
      <circle cx="15.6" cy="13.6" r="0.7" fill="#FFFFFF">
        <animate attributeName="opacity" values="1;0.2;1" dur="0.9s" repeatCount="indefinite"/>
      </circle>

      {/* Solar flare glint — short rays radiating from upper-right of body */}
      <g stroke="#FEF3C7" stroke-width="0.5" stroke-linecap="round" opacity="0.9">
        <line x1="23" y1="12.5" x2="26" y2="10">
          <animate attributeName="opacity" values="0.5;1;0.5" dur="2.8s" repeatCount="indefinite"/>
        </line>
        <line x1="24" y1="13.5" x2="27" y2="12.8">
          <animate attributeName="opacity" values="1;0.5;1" dur="2.8s" repeatCount="indefinite"/>
        </line>
        <line x1="23.5" y1="12" x2="25.5" y2="8.5">
          <animate attributeName="opacity" values="0.6;1;0.6" dur="3.2s" repeatCount="indefinite"/>
        </line>
      </g>
      <circle cx="23.5" cy="12.5" r="1" fill="#FEF9C3" opacity="0.85">
        <animate attributeName="opacity" values="0.6;1;0.6" dur="2.8s" repeatCount="indefinite"/>
      </circle>
    </g>
  </svg>
)}

{slug === 'bites' && (
  /* Phase D — Bites = formation-flying companion to Long videos. Same
     YouTube DNA (red play body, panels, antenna) but smaller and tighter
     so they read as related-but-distinct. Sush note: Bites = 10–20 min
     videos (NOT YouTube Shorts) — a real distribution channel for
     coffee-break-length cuts. ONE trailing motion line (not three swipe
     chevrons) hints at "shorter pace" without invoking Shorts vocabulary.
     A subtle "10-20" timecode hint is rendered in mono on the body so
     the size promise is legible at a glance. */
  <svg viewBox="0 0 34 32" width={size * 1.06} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Soft pink-red warmth — matches Long videos but a touch cooler */}
    <ellipse cx="17" cy="16" rx="14" ry="9" fill="#9F1239" opacity="0.18"/>

    {/* Single trailing motion line behind the body — hints "this one moves
        faster / shorter" without reading as "shorts swipe". */}
    <g stroke="#FECACA" stroke-width="0.6" stroke-linecap="round" opacity="0.55">
      <line x1="2" y1="16" x2="6.5" y2="16">
        <animate attributeName="opacity" values="0.85;0.2;0.85" dur="1.4s" repeatCount="indefinite"/>
      </line>
    </g>

    {/* Whole satellite — slightly faster wobble than Long videos, signalling
        the tighter rhythm of bite-sized publishing. */}
    <g>
      <animateTransform attributeName="transform" type="rotate"
                        values="-2 17 16; 2 17 16; -2 17 16"
                        dur="3.6s" repeatCount="indefinite"/>

      {/* LEFT solar panel — smaller than Long videos to telegraph "junior
          sibling" (same DNA, smaller body). */}
      <g>
        <rect x="1.5" y="13" width="6.5" height="6" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
        <line x1="3.6" y1="13" x2="3.6" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="5.7" y1="13" x2="5.7" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="1.5" y1="16" x2="8" y2="16" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="8" y1="16" x2="11" y2="16" stroke="#94A3B8" stroke-width="0.55"/>
      </g>

      {/* RIGHT solar panel — mirrored */}
      <g>
        <rect x="26" y="13" width="6.5" height="6" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
        <line x1="28.1" y1="13" x2="28.1" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="30.2" y1="13" x2="30.2" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="26" y1="16" x2="32.5" y2="16" stroke="#60A5FA" stroke-width="0.3"/>
        <line x1="23" y1="16" x2="26" y2="16" stroke="#94A3B8" stroke-width="0.55"/>
      </g>

      {/* Antenna — short whisker with blinking transmitter dot */}
      <line x1="17" y1="11" x2="17" y2="6.8" stroke="#94A3B8" stroke-width="0.6"/>
      <circle cx="17" cy="6.5" r="0.85" fill="#FCA5A5">
        <animate attributeName="opacity" values="0.4;1;0.4" dur="1.4s" repeatCount="indefinite"/>
      </circle>

      {/* Central body — horizontal red rounded rect (same orientation as
          Long videos, just smaller). Distinguishing pink-red tint vs the
          deep red of Long videos. */}
      <rect x="11" y="11" width="12" height="10" rx="1.6" ry="1.6" fill="#F43F5E" stroke="#FECDD3" stroke-width="0.4">
        <animate attributeName="opacity" values="0.92;1;0.92" dur="2.2s" repeatCount="indefinite"/>
      </rect>
      <polygon points="13.6,13.6 13.6,18.4 17.5,16" fill="#FFFFFF"/>

      {/* "10–20" timecode label — tiny mono text inside the right side
          of the body. Tells the user this channel is 10–20 min videos at
          a single glance, distinguishing from Long videos. */}
      <text x="20.6" y="14.4" text-anchor="middle"
            font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
            font-size="3.2" font-weight="700" fill="#FFFFFF" opacity="0.95">10</text>
      <text x="20.6" y="18.6" text-anchor="middle"
            font-family="ui-monospace, SFMono-Regular, Menlo, monospace"
            font-size="3.2" font-weight="700" fill="#FFFFFF" opacity="0.95">20</text>
      <line x1="18.4" y1="16.5" x2="22.8" y2="16.5" stroke="#FECDD3" stroke-width="0.35" opacity="0.85"/>

      {/* REC indicator — small white blinking dot, slightly faster than
          Long videos to telegraph "more frequent uploads" */}
      <circle cx="12.4" cy="12.5" r="0.55" fill="#FFFFFF">
        <animate attributeName="opacity" values="1;0.2;1" dur="0.7s" repeatCount="indefinite"/>
      </circle>

      {/* Solar flare glint — upper-right of body */}
      <g stroke="#FEF3C7" stroke-width="0.45" stroke-linecap="round" opacity="0.85">
        <line x1="22" y1="12" x2="24.4" y2="9.8">
          <animate attributeName="opacity" values="0.5;1;0.5" dur="2.4s" repeatCount="indefinite"/>
        </line>
        <line x1="23" y1="12.8" x2="25.4" y2="12.2">
          <animate attributeName="opacity" values="1;0.5;1" dur="2.4s" repeatCount="indefinite"/>
        </line>
      </g>
      <circle cx="22.4" cy="12.2" r="0.85" fill="#FEF9C3" opacity="0.85">
        <animate attributeName="opacity" values="0.6;1;0.6" dur="2.4s" repeatCount="indefinite"/>
      </circle>
    </g>
  </svg>
)}

{slug === 'linkedin' && (
  /* Phase B-2 — LinkedIn passing comet. Cool blue palette to differentiate
     from the warm YouTube body. Cleaner satellite — single dish-style
     parabolic antenna instead of solar panels, a stylised "in" wordmark
     in the central rounded square, plus 3 connection-pulse rings beneath
     suggesting "professional network". Slow gentle wobble. */
  <svg viewBox="0 0 34 32" width={size * 1.06} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Soft cool glow */}
    <ellipse cx="17" cy="16" rx="15" ry="10" fill="#0C4A6E" opacity="0.22"/>

    {/* Connection pulse rings underneath — three faint arcs that hint at
        "network" — staggered opacity creates a quiet pulse */}
    <g fill="none" stroke="#7DD3FC" stroke-linecap="round" opacity="0.55">
      <path d="M 8 26 Q 17 30 26 26" stroke-width="0.7">
        <animate attributeName="opacity" values="0.2;0.85;0.2" dur="2.6s" repeatCount="indefinite"/>
      </path>
      <path d="M 6 28 Q 17 33 28 28" stroke-width="0.5">
        <animate attributeName="opacity" values="0.85;0.2;0.85" dur="2.6s" repeatCount="indefinite"/>
      </path>
      <path d="M 4 30 Q 17 36 30 30" stroke-width="0.4">
        <animate attributeName="opacity" values="0.2;0.85;0.2" dur="2.6s" begin="0.7s" repeatCount="indefinite"/>
      </path>
    </g>

    {/* Whole satellite gentle wobble */}
    <g>
      <animateTransform attributeName="transform" type="rotate"
                        values="-1.6 17 16; 1.6 17 16; -1.6 17 16"
                        dur="5.2s" repeatCount="indefinite"/>

      {/* Parabolic dish on the left — open arc */}
      <path d="M 5 12 A 4 6 0 0 1 5 22" fill="none" stroke="#60A5FA" stroke-width="1.4" stroke-linecap="round"/>
      <line x1="5" y1="17" x2="11" y2="17" stroke="#94A3B8" stroke-width="0.5"/>
      <circle cx="5" cy="17" r="0.9" fill="#7DD3FC"/>

      {/* Right outrigger — short antenna boom */}
      <line x1="22" y1="17" x2="29" y2="17" stroke="#94A3B8" stroke-width="0.5"/>
      <circle cx="29" cy="17" r="0.8" fill="#7DD3FC">
        <animate attributeName="opacity" values="0.5;1;0.5" dur="1.4s" repeatCount="indefinite"/>
      </circle>

      {/* Antenna up top */}
      <line x1="17" y1="11" x2="17" y2="6.5" stroke="#94A3B8" stroke-width="0.6"/>
      <circle cx="17" cy="6.2" r="0.8" fill="#7DD3FC">
        <animate attributeName="opacity" values="0.4;1;0.4" dur="1.6s" repeatCount="indefinite"/>
      </circle>

      {/* Central LinkedIn body — squared rounded rect with stylised "in" */}
      <rect x="11" y="11" width="12" height="12" rx="2" ry="2" fill="#0284C7" stroke="#7DD3FC" stroke-width="0.5">
        <animate attributeName="opacity" values="0.92;1;0.92" dur="2.4s" repeatCount="indefinite"/>

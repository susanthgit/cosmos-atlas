---
/**
 * PlanetIcon — atlas-vendored canonical 7-icon contract from cosmos rail
 * (mirrors aguidetocloud-revamp/layouts/partials/planet-icon.html and siblings).
 * Adds curriculum (Plain AI moon) and mcp (the star).
 *
 * IconSlug ⊇ planets.json slugs:
 *   earth · guided · brainbar · shift · plainai · agentic · claw · curriculum · mcp
 */
interface Props {
  slug: 'earth' | 'guided' | 'brainbar' | 'shift' | 'plainai' | 'agentic' | 'claw' | 'curriculum' | 'mcp' | 'long-form' | 'bites' | 'kofi';
  size?: number;
  scope?: string;
}
const { slug, size = 32, scope = 'atlas' } = Astro.props;
const gradId = `pa-${scope}-${slug}-grad`;
const maskId = `pa-${scope}-${slug}-mask`;
---

{slug === 'earth' && (
  /* V3 polish #8 — AVIF lotus with WebP fallback. ~30% smaller, identical visual. */
  <picture>
    <source srcset="/planets/earth-lotus.avif" type="image/avif" />
    <img
      src="/planets/earth-lotus.webp"
      width={size}
      height={size}
      alt=""
      loading="eager"
      decoding="async"
      style={`width:${size}px;height:${size}px;object-fit:contain;display:block`}
    />
  </picture>
)}

{slug === 'guided' && (
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <mask id={maskId}>
      <rect width="32" height="32" fill="white"/>
      <circle cx="20" cy="13" r="11" fill="black"/>
    </mask>
    <circle cx="16" cy="16" r="13" fill="#E0D7BE" mask={`url(#${maskId})`}/>
  </svg>
)}

{slug === 'brainbar' && (
  <svg viewBox="0 0 24 24" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <text x="6" y="16" font-family="ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13" font-weight="700" fill="#86EFAC">$</text>
    <line x1="14" y1="14" x2="20" y2="14" stroke="#86EFAC" stroke-width="2.2" stroke-linecap="round">
      <animate attributeName="opacity" values="1;0" keyTimes="0;0.5" dur="1.2s" repeatCount="indefinite" calcMode="discrete"/>
    </line>
  </svg>
)}

{slug === 'shift' && (
  <svg viewBox="0 0 60 60" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <circle cx="30" cy="30" r="27" fill="none" stroke="#FDBA74" stroke-width="2.5"/>
    <circle cx="30" cy="30" r="22" fill="none" stroke="#FDBA74" stroke-width="1" opacity=".55"/>
    <path d="M 30 30 L 42.6 11.6 A 22 22 0 0 1 52 30 Z" fill="#E25822" opacity=".28">
      <animate attributeName="opacity" values=".18;.32;.18" dur="3s" repeatCount="indefinite"/>
    </path>
    <line x1="30" y1="30" x2="46" y2="14" stroke="#E25822" stroke-width="2.6" stroke-linecap="round">
      <animateTransform attributeName="transform" type="rotate" values="-3 30 30;3 30 30;-3 30 30" dur="4s" repeatCount="indefinite"/>
    </line>
    <circle cx="30" cy="30" r="3.2" fill="#FDBA74"/>
  </svg>
)}

{slug === 'plainai' && (
  <svg viewBox="0 0 38 30" width={size * 1.27} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#67E8F9"/>
        <stop offset="50%" stop-color="#A78BFA"/>
        <stop offset="100%" stop-color="#F472B6"/>
      </linearGradient>
    </defs>
    <path d="M4 3 a3 3 0 0 1 3-3 h24 a3 3 0 0 1 3 3 v15 a3 3 0 0 1 -3 3 h-15 l-6 5 v-5 h-3 a3 3 0 0 1 -3 -3 z"
          fill={`url(#${gradId})`}/>
    <text x="19" y="11.5" text-anchor="middle" dominant-baseline="middle"
          font-family="Inter, system-ui, sans-serif" font-size="11" font-weight="800"
          fill="white" letter-spacing="-0.04em">AI</text>
  </svg>
)}

{slug === 'curriculum' && (
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <defs>
      <linearGradient id={gradId} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#BBF7D0"/>
        <stop offset="100%" stop-color="#22C55E"/>
      </linearGradient>
    </defs>
    <path d="M16 28 V14" stroke="#86EFAC" stroke-width="1.8" stroke-linecap="round" fill="none"/>
    <path d="M16 18 C12 18 8 16 7 12 C12 12 16 14 16 18 Z" fill={`url(#${gradId})`}/>
    <path d="M16 16 C20 16 24 14 25 10 C20 10 16 12 16 16 Z" fill={`url(#${gradId})`}/>
    <circle cx="16" cy="14" r="1.4" fill="#16A34A"/>
  </svg>
)}

{slug === 'agentic' && (
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <circle cx="16" cy="16" r="11" fill="#0EA5E9" opacity="0.12"/>
    <circle cx="16" cy="16" r="7" fill="#0EA5E9" opacity="0.22"/>
    <circle cx="16" cy="16" r="4" fill="#7DD3FC">
      <animate attributeName="opacity" values="1;0.55;1" dur="2.4s" repeatCount="indefinite"/>
    </circle>
    <circle cx="16" cy="16" r="1.6" fill="#F2EDE3"/>
  </svg>
)}

{slug === 'claw' && (
  <svg viewBox="0 0 24 24" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path d="M7 4 L4 4 L4 20 L7 20" stroke="#F2EDE3" stroke-width="2.2" fill="none" stroke-linecap="round"/>
    <path d="M17 4 L20 4 L20 20 L17 20" stroke="#F2EDE3" stroke-width="2.2" fill="none" stroke-linecap="round"/>
    <g stroke="#FF2626" stroke-width="2" stroke-linecap="round" fill="none">
      <line x1="12" y1="8" x2="12" y2="16"/>
      <line x1="8.5" y1="9.5" x2="15.5" y2="14.5"/>
      <line x1="15.5" y1="9.5" x2="8.5" y2="14.5"/>
    </g>
  </svg>
)}

{slug === 'mcp' && (
  /* V3.1 — unambiguous "star" icon. Five gold points with a bright core, plus four
     subtle longer rays (the MCP "reaching to all planets" metaphor). Distinct from
     Claw's `[*]` brand mark so the cosmos's one-true-star reads as a star at a glance. */
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Long thin rays — the MCP "reach" — pulse softly */}
    <g stroke="#FFB347" stroke-width="0.9" stroke-linecap="round" opacity="0.55">
      <line x1="16" y1="1" x2="16" y2="6">
        <animate attributeName="opacity" values="0.3;0.75;0.3" dur="2.4s" repeatCount="indefinite"/>
      </line>
      <line x1="16" y1="26" x2="16" y2="31">
        <animate attributeName="opacity" values="0.75;0.3;0.75" dur="2.4s" repeatCount="indefinite"/>
      </line>
      <line x1="1" y1="16" x2="6" y2="16">
        <animate attributeName="opacity" values="0.3;0.75;0.3" dur="2.8s" repeatCount="indefinite"/>
      </line>
      <line x1="26" y1="16" x2="31" y2="16">
        <animate attributeName="opacity" values="0.75;0.3;0.75" dur="2.8s" repeatCount="indefinite"/>
      </line>
    </g>
    {/* Five-point star body — gold fill, outline for crispness on dark background */}
    <polygon
      points="16,4 19.4,12.4 28.4,12.4 21.1,17.6 23.9,26 16,20.8 8.1,26 10.9,17.6 3.6,12.4 12.6,12.4"
      fill="#FFD89A"
      stroke="#FFB347"
      stroke-width="0.9"
      stroke-linejoin="round"
    >
      <animate attributeName="opacity" values="0.92;1;0.92" dur="2s" repeatCount="indefinite"/>
    </polygon>
    {/* Bright pulsing core */}
    <circle cx="16" cy="16" r="2.2" fill="#FFFFFF" opacity="0.9">
      <animate attributeName="r" values="1.8;2.6;1.8" dur="2s" repeatCount="indefinite"/>
    </circle>
  </svg>
)}

{slug === 'long-form' && (
  /* V3.3.1 — Long-form YouTube as a manmade SATELLITE.
     Real-world satellite character: central body holds the YouTube branding
     (red rect + play triangle), flanked by two solar panel arrays (blue
     gridded rectangles), with an antenna up top and a solar flare glint on
     the upper-right. Reads as "a satellite broadcasting long-form content"
     not just a floating brand logo. */
  <svg viewBox="0 0 36 32" width={size * 1.13} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Soft outer warmth so the body has presence on dark canvas */}
    <ellipse cx="18" cy="16" rx="17" ry="9" fill="#7F1D1D" opacity="0.16"/>

    {/* LEFT solar panel — blue gridded rectangle, struts to body */}
    <g>
      <rect x="1" y="13" width="9" height="6" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
      <line x1="4" y1="13" x2="4" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="7" y1="13" x2="7" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="1" y1="16" x2="10" y2="16" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="10" y1="16" x2="13" y2="16" stroke="#94A3B8" stroke-width="0.6"/>
    </g>

    {/* RIGHT solar panel — mirrored */}
    <g>
      <rect x="26" y="13" width="9" height="6" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
      <line x1="29" y1="13" x2="29" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="32" y1="13" x2="32" y2="19" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="26" y1="16" x2="35" y2="16" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="23" y1="16" x2="26" y2="16" stroke="#94A3B8" stroke-width="0.6"/>
    </g>

    {/* Antenna — short whisker with blinking transmitter dot */}
    <line x1="18" y1="11" x2="18" y2="6" stroke="#94A3B8" stroke-width="0.7"/>
    <circle cx="18" cy="5.5" r="0.9" fill="#FCA5A5">
      <animate attributeName="opacity" values="0.4;1;0.4" dur="1.6s" repeatCount="indefinite"/>
    </circle>

    {/* Central satellite body — YouTube red rounded rect with play triangle */}
    <rect x="13" y="11" width="10" height="10" rx="1.6" ry="1.6" fill="#DC2626" stroke="#FCA5A5" stroke-width="0.4">
      <animate attributeName="opacity" values="0.92;1;0.92" dur="2.4s" repeatCount="indefinite"/>
    </rect>
    <polygon points="15.6,13.5 15.6,18.5 20.4,16" fill="#FFFFFF"/>

    {/* Solar flare glint — short rays radiating from upper-right corner of body */}
    <g stroke="#FEF3C7" stroke-width="0.5" stroke-linecap="round" opacity="0.9">
      <line x1="22" y1="11.5" x2="25" y2="9">
        <animate attributeName="opacity" values="0.5;1;0.5" dur="2.8s" repeatCount="indefinite"/>
      </line>
      <line x1="23" y1="12.5" x2="26" y2="11.8">
        <animate attributeName="opacity" values="1;0.5;1" dur="2.8s" repeatCount="indefinite"/>
      </line>
      <line x1="22.5" y1="11" x2="24.5" y2="7.5">
        <animate attributeName="opacity" values="0.6;1;0.6" dur="3.2s" repeatCount="indefinite"/>
      </line>
    </g>
    <circle cx="22.5" cy="11.5" r="1" fill="#FEF9C3" opacity="0.85">
      <animate attributeName="opacity" values="0.6;1;0.6" dur="2.8s" repeatCount="indefinite"/>
    </circle>
  </svg>
)}

{slug === 'bites' && (
  /* V3.3.1 — Bites = compact Shorts SATELLITE. Same satellite vocabulary as
     long-form (panels + antenna + flare glint) but with a vertical Shorts-aspect
     central body to differentiate. Smaller, more nimble — feels like the
     companion satellite to the bigger long-form bird. */
  <svg viewBox="0 0 32 32" width={size} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Soft glow */}
    <ellipse cx="16" cy="16" rx="14" ry="11" fill="#9F1239" opacity="0.16"/>

    {/* LEFT solar panel — vertical, smaller than long-form */}
    <g>
      <rect x="2" y="11.5" width="6" height="9" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
      <line x1="5" y1="11.5" x2="5" y2="20.5" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="2" y1="14.5" x2="8" y2="14.5" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="2" y1="17.5" x2="8" y2="17.5" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="8" y1="16" x2="11" y2="16" stroke="#94A3B8" stroke-width="0.6"/>
    </g>

    {/* RIGHT solar panel — mirrored */}
    <g>
      <rect x="24" y="11.5" width="6" height="9" fill="#1E3A8A" stroke="#60A5FA" stroke-width="0.4"/>
      <line x1="27" y1="11.5" x2="27" y2="20.5" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="24" y1="14.5" x2="30" y2="14.5" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="24" y1="17.5" x2="30" y2="17.5" stroke="#60A5FA" stroke-width="0.3"/>
      <line x1="21" y1="16" x2="24" y2="16" stroke="#94A3B8" stroke-width="0.6"/>
    </g>

    {/* Antenna — slightly shorter than long-form's, with transmitter dot */}
    <line x1="16" y1="6" x2="16" y2="2.5" stroke="#94A3B8" stroke-width="0.6"/>
    <circle cx="16" cy="2.2" r="0.7" fill="#FCA5A5">
      <animate attributeName="opacity" values="0.4;1;0.4" dur="1.4s" repeatCount="indefinite"/>
    </circle>

    {/* Central satellite body — vertical Shorts rounded rect */}
    <rect x="11" y="6" width="10" height="20" rx="2" ry="2" fill="#F43F5E" stroke="#FECDD3" stroke-width="0.4">
      <animate attributeName="opacity" values="0.92;1;0.92" dur="2s" repeatCount="indefinite"/>
    </rect>
    {/* Centred play triangle */}
    <polygon points="13.6,13 13.6,19 18.6,16" fill="#FFFFFF"/>
    {/* Tiny swipe-up chevron — inside body, hints at Shorts swipe gesture */}
    <polyline points="13.5,9.5 16,8 18.5,9.5" stroke="#FFFFFF" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.85">
      <animate attributeName="opacity" values="0.4;1;0.4" dur="1.2s" repeatCount="indefinite"/>
    </polyline>
    <polyline points="13.5,22.5 16,24 18.5,22.5" stroke="#FFFFFF" stroke-width="1" stroke-linecap="round" fill="none" opacity="0.85">
      <animate attributeName="opacity" values="1;0.4;1" dur="1.2s" repeatCount="indefinite"/>
    </polyline>

    {/* Solar flare glint — upper-right of body */}
    <g stroke="#FEF3C7" stroke-width="0.45" stroke-linecap="round" opacity="0.9">
      <line x1="20.5" y1="7" x2="23" y2="4.5">
        <animate attributeName="opacity" values="0.5;1;0.5" dur="2.6s" repeatCount="indefinite"/>
      </line>
      <line x1="21.5" y1="8" x2="24" y2="7">
        <animate attributeName="opacity" values="1;0.5;1" dur="2.6s" repeatCount="indefinite"/>
      </line>
    </g>
    <circle cx="20.8" cy="7.3" r="0.85" fill="#FEF9C3" opacity="0.85">
      <animate attributeName="opacity" values="0.6;1;0.6" dur="2.6s" repeatCount="indefinite"/>
    </circle>
  </svg>
)}

{slug === 'kofi' && (
  /* V3.3 — Ko-fi reimagined. No more "tiny solar system in the corner". One
     warm coffee mug with a heart-shaped spot (Ko-fi's actual brand feel),
     gently glowing. Heart-on-mug = the give-and-receive mark. */
  <svg viewBox="0 0 36 32" width={size * 1.13} height={size} xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    {/* Outer warm glow */}
    <ellipse cx="18" cy="17" rx="15" ry="12" fill="#F97316" opacity="0.16">
      <animate attributeName="opacity" values="0.10;0.22;0.10" dur="3.6s" repeatCount="indefinite"/>
    </ellipse>
    {/* Cup body — rounded mug, off-white with warm shadow */}
    <path
      d="M 6 11 Q 6 9 8 9 L 24 9 Q 26 9 26 11 L 26 22 Q 26 26 22 26 L 10 26 Q 6 26 6 22 Z"
      fill="#FFFBEA"
      stroke="#F97316"
      stroke-width="1.4"
      stroke-linejoin="round"
    />
    {/* Cup handle — rightward arc */}
    <path
      d="M 26 13 Q 31 13 31 17 Q 31 21 26 21"
      fill="none"
      stroke="#F97316"
      stroke-width="1.6"
      stroke-linecap="round"
    />
    {/* Heart on the mug — the Ko-fi mark itself */}
    <path
      d="M 16 21 C 16 21, 10 17, 10 13.5 C 10 11.6, 11.4 10.5, 13 10.5 C 14.5 10.5, 15.5 11.5, 16 12.4 C 16.5 11.5, 17.5 10.5, 19 10.5 C 20.6 10.5, 22 11.6, 22 13.5 C 22 17, 16 21, 16 21 Z"
      fill="#EF4444"
    >
      <animate attributeName="opacity" values="0.92;1;0.92" dur="1.8s" repeatCount="indefinite"/>
    </path>
    {/* Gentle steam wisps */}
    <path d="M 11 5 Q 12 3 11 1" fill="none" stroke="#FECACA" stroke-width="1.2" stroke-linecap="round" opacity="0.7">
      <animate attributeName="opacity" values="0.3;0.85;0.3" dur="2.2s" repeatCount="indefinite"/>
    </path>
    <path d="M 16 5 Q 17 3 16 1" fill="none" stroke="#FECACA" stroke-width="1.2" stroke-linecap="round" opacity="0.7">
      <animate attributeName="opacity" values="0.85;0.3;0.85" dur="2.2s" repeatCount="indefinite"/>
    </path>
    <path d="M 21 5 Q 22 3 21 1" fill="none" stroke="#FECACA" stroke-width="1.2" stroke-linecap="round" opacity="0.7">
      <animate attributeName="opacity" values="0.3;0.85;0.3" dur="2.2s" begin="0.7s" repeatCount="indefinite"/>
    </path>
  </svg>
)}

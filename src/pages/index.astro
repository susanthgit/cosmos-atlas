---
import Base from '../layouts/Base.astro';
import PlanetIcon from '../components/PlanetIcon.astro';
import planets from '../data/planets.json';
import atlas from '../data/atlas.json';

// V3 #1 — sitemap-driven freshness. If freshness.json exists (built by
// `npm run freshness`), it overrides the manual lastShippedAt in atlas.json.
// We import lazily so the build doesn't break if the file is absent
// (e.g. someone clones the repo and runs `npm run dev` before freshness).
let freshness: { planets?: Record<string, { lastShippedAt?: string; source?: string }> } = {};
try {
  // Astro/Vite resolves this at build time; ?raw ensures graceful fallback.
  const mod = await import('../data/freshness.json');
  freshness = (mod.default ?? mod) as typeof freshness;
} catch (_) {
  // No freshness file yet — fall back to atlas lastShippedAt.
}
function freshnessFor(slug: string): string | undefined {
  return freshness.planets?.[slug]?.lastShippedAt;
}

type ManifestPlanet = { slug: string; name: string; url: string; tagline: string };
type AtlasMoon = { slug: string; name?: string; url?: string; type: string; atmosphere: string; status: string; badge?: string; tagline: string; audience: string; content: string; founder: string; stats?: string[]; orbit: { radius: number; speedSec: number; phase?: number }; body: { size: number; glowCore: string; glowOuter: string } };
type AtlasPlanet = { slug: string; name?: string; url?: string; type: string; atmosphere: string; status: string; badge?: string; tagline: string; audience: string; content: string; founder: string; stats?: string[]; orbit: { radius: number; ecc: number; tilt: number; speedSec: number; phase: number }; body: { size: number; glowCore: string; glowOuter: string }; moons?: AtlasMoon[] };

type IconSlug = 'earth' | 'guided' | 'brainbar' | 'shift' | 'plainai' | 'agentic' | 'claw' | 'curriculum' | 'mcp' | 'long-form' | 'bites' | 'kofi-shop' | 'kofi-tip';

const manifestBySlug = new Map<string, ManifestPlanet>();
for (const p of planets.planets as ManifestPlanet[]) {
  manifestBySlug.set(p.slug, p);
}

const composed = (atlas.planets as AtlasPlanet[]).map((p) => {
  const m = manifestBySlug.get(p.slug);
  const moons = (p.moons ?? []).map((moon) => {
    const moonManifest = manifestBySlug.get(moon.slug);
    return {
      ...moon,
      name: moonManifest?.name ?? moon.name ?? moon.slug,
      url: moonManifest?.url ?? moon.url ?? '',
      lastShippedAt: freshnessFor(moon.slug) ?? (moon as { lastShippedAt?: string }).lastShippedAt,
    };
  });
  return {
    ...p,
    name: m?.name ?? p.name ?? p.slug,
    url: m?.url ?? p.url ?? '',
    lastShippedAt: freshnessFor(p.slug) ?? (p as { lastShippedAt?: string }).lastShippedAt,
    moons,
  };
});

// MCP star also takes a freshness override.
const mcpEnriched = {
  ...atlas.mcp,
  lastShippedAt: freshnessFor(atlas.mcp.slug) ?? (atlas.mcp as { lastShippedAt?: string }).lastShippedAt,
};

// JSON-LD — SiteNavigationElement so search engines understand the planet list
const navItems = composed.flatMap((p) => {
  const items: Array<{ name: string; url: string }> = [{ name: p.name, url: p.url }];
  for (const moon of p.moons ?? []) {
    if (moon.url) items.push({ name: moon.name, url: moon.url });
  }
  return items;
});
navItems.push({ name: atlas.mcp.name, url: atlas.mcp.url });

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Cosmos Atlas',
  url: 'https://cosmos.aguidetocloud.com/',
  description: 'A living solar system mapping the A Guide to Cloud cosmos.',
  publisher: {
    '@type': 'Person',
    name: 'Susanth Sutheesh',
  },
  hasPart: navItems.map((n) => ({
    '@type': 'WebPage',
    name: n.name,
    url: n.url,
  })),
};

// Pass merged data + atmosphere to the client-side canvas controller
const clientData = {
  atmosphere: atlas.atmosphere,
  sun: atlas.sun,
  planets: composed,
  mcp: mcpEnriched,
  decorativeStars: atlas.decorativeStars,
  external: atlas.external ?? { channels: [] },
};
---

<Base
  title="Cosmos Atlas — A Guide to Cloud"
  description="A living solar system mapping the A Guide to Cloud cosmos. Click a planet to learn what it is, where it sits, who it's for."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <main class="cosmos" data-state="idle" data-js="pending" id="cosmos-root">
    <!-- Canvas — orbit ellipses, sun glow, starfield, body halos -->
    <canvas
      class="canvas-stage"
      id="cosmos-canvas"
      aria-hidden="true"
    ></canvas>

    <!-- Planet bodies — HTML overlays positioned in real time by cosmos.ts.
         Crisp SVG logos. Pointer events live here, not on the canvas. -->
    <div class="bodies" id="bodies" aria-label="A Guide to Cloud cosmos — 7 planets, 2 moons, 1 star">
      {composed.map((p) => (
        <>
          <button
            class="planet-body"
            data-slug={p.slug}
            data-kind="planet"
            type="button"
            aria-label={`${p.name} · ${p.tagline}`}
          >
            <span class="planet-body__icon">
              <PlanetIcon slug={p.slug as IconSlug} size={56} scope={`atlas-${p.slug}`} />
            </span>
          </button>
          {(p.moons ?? []).map((m) => (
            <button
              class="planet-body planet-body--moon"
              data-slug={m.slug}
              data-kind="moon"
              data-parent={p.slug}
              type="button"
              aria-label={`${m.name} · ${m.tagline}`}
            >
              <span class="planet-body__icon">
                <PlanetIcon slug={m.slug as IconSlug} size={36} scope={`atlas-${m.slug}`} />
              </span>
            </button>
          ))}
        </>
      ))}
      <!-- MCP star — fixed-canvas-position pulsing star -->
      <button
        class="planet-body planet-body--star"
        data-slug={atlas.mcp.slug}
        data-kind="star"
        type="button"
        aria-label={`${atlas.mcp.name} · ${atlas.mcp.tagline}`}
      >
        <span class="planet-body__icon">
          <PlanetIcon slug="mcp" size={40} scope="atlas-mcp" />
        </span>
      </button>

      {/* V3.2 — external channels (YouTubes + Ko-fi). Kind is resolved at runtime
           by cosmos.ts based on URL param ?ext=comets|outposts. data-kind here
           is "external" — gets rewritten by JS to comet/beacon/outpost.
           V3.3 — Ko-fi satellites removed; Ko-fi card now has two CTAs instead. */}
      {(atlas.external?.channels ?? []).map((ch) => (
        <button
          class="planet-body planet-body--external"
          data-slug={ch.slug}
          data-kind="external"
          type="button"
          aria-label={`${ch.name} · ${ch.tagline}`}
        >
          <span class="planet-body__icon">
            <PlanetIcon slug={ch.slug as IconSlug} size={32} scope={`atlas-${ch.slug}`} />
          </span>
        </button>
      ))}
    </div>

    <!-- HUD overlay -->
    <div class="hud" role="presentation">
      <header class="hud-mast">
        <strong class="mast-mark">🌌 Cosmos Atlas</strong>
        <span class="mast-rule" aria-hidden="true"></span>
        <span class="mast-tag">A Guide to Cloud</span>
      </header>

      {/* V3.5 — One-line lede above the canvas. Fades after ~6s once user
           sees it. Suppressed when first-visit coach is going to show
           (coach explains the same things and more). */}
      <p class="cosmos-lede" id="cosmos-lede" data-visible="false" aria-live="polite">
        a living map of everything in the A Guide to Cloud cosmos. tap a planet to start.
      </p>

      <nav class="hud-tools" aria-label="View tools">
        <button
          type="button"
          class="hud-btn"
          id="toggle-list"
          aria-pressed="false"
          aria-label="Tap to read the planet list view"
          title="Tap for the static planet list (great for screen readers)"
        >
          📋 List view
        </button>
      </nav>

      <p class="hud-hint" aria-hidden="true">Hover · click a planet to see what it is</p>

      <ul class="hud-shortcuts" aria-hidden="true">
        <li><kbd>1</kbd>–<kbd>6</kbd> · focus</li>
        <li><kbd>0</kbd> · MCP star</li>
        <li><kbd>⇧</kbd>+drag · tilt</li>
        <li>wheel · zoom</li>
        <li><kbd>R</kbd> · reset</li>
      </ul>

      <p class="hud-attribution">
        <a href="https://www.aguidetocloud.com/about/" rel="noopener">by A Guide to Cloud</a>
      </p>

      <div class="planet-label" id="planet-label" data-visible="false" role="status" aria-live="polite"></div>

      <!-- V3 #7 — first-mobile-visit gesture hint. Hidden by default; cosmos.ts shows it once. -->
      <div class="gesture-hint" id="gesture-hint" data-visible="false" aria-hidden="true">
        <span class="gesture-hint__line">↔ swipe to pan</span>
        <span class="gesture-hint__line">⊕ pinch to zoom</span>
        <span class="gesture-hint__line">tap a planet to open</span>
      </div>

      {/* V3.5 — First-visit coach. 3 cards, dismissable. Sets
           localStorage.cosmosCoachSeen so it never repeats for the same
           visitor. Suppresses the lede when active. */}
      <div
        class="cosmos-coach"
        id="cosmos-coach"
        data-step="0"
        data-visible="false"
        role="dialog"
        aria-labelledby="coach-title-0"
        aria-modal="false"
      >
        <button class="cosmos-coach__skip" id="coach-skip" type="button" aria-label="Skip the intro">Skip</button>
        <div class="cosmos-coach__step cosmos-coach__step--0">
          <span class="cosmos-coach__title" id="coach-title-0">a quick tour · 1 of 3</span>
          <p class="cosmos-coach__body">this is the cosmos — a living map of <strong>A Guide to Cloud</strong>. each planet is a different audience.</p>
        </div>
        <div class="cosmos-coach__step cosmos-coach__step--1">
          <span class="cosmos-coach__title" id="coach-title-1">the source · 2 of 3</span>
          <p class="cosmos-coach__body">the glow at the centre is the <strong>Sun</strong> — the AI co-founder. invisible by design.</p>
        </div>
        <div class="cosmos-coach__step cosmos-coach__step--2">
          <span class="cosmos-coach__title" id="coach-title-2">how to roam · 3 of 3</span>
          <p class="cosmos-coach__body"><strong>Earth</strong> is the home. tap it to start. drag to pan · wheel to zoom · tap any planet.</p>
        </div>
        <div class="cosmos-coach__nav">
          <span class="cosmos-coach__dots" aria-hidden="true">
            <span class="cosmos-coach__dot"></span>
            <span class="cosmos-coach__dot"></span>
            <span class="cosmos-coach__dot"></span>
          </span>
          <button class="cosmos-coach__btn" id="coach-back" type="button">← back</button>
          <button class="cosmos-coach__btn cosmos-coach__btn--primary" id="coach-next" type="button">next →</button>
        </div>
      </div>
    </div>

    <!-- Card panel — slides in when a planet/moon is opened -->
    <aside
      class="card-panel"
      id="card-panel"
      data-open="false"
      aria-labelledby="card-name"
      aria-hidden="true"
      role="complementary"
    >
      <button
        type="button"
        class="card-close"
        id="card-close"
        aria-label="Close planet card"
      >×</button>
      <div class="card-body" id="card-body"></div>
    </aside>

    <!-- Static SSR fallback — visible without JS, hidden when canvas mounts -->
    <article class="static-shell" id="static-shell">
      <header class="static-hero">
        <h1>The cosmos, mapped.</h1>
        <p>A growing universe of planets, moons, and a star — each one for a different audience, each with its own atmosphere. The interactive version turns this list into a living solar system. This is the honest fallback.</p>
        <p class="static-fallback-note">
          You're reading the static planet list. It's here for screen readers, search engines, low-bandwidth visitors, and anyone whose JavaScript is off. The interactive version lives at the same URL — refresh once JS is enabled.
        </p>
      </header>

      <section class="static-section" aria-labelledby="sun-heading">
        <span class="section-tag">☀️ The source</span>
        <h2 id="sun-heading">{atlas.sun.label}</h2>
        <p class="lede">{atlas.sun.subLabel} — every planet exists because something is feeding it. The Sun does not show up on any planet's surface. By design.</p>
      </section>

      <section class="static-section" aria-labelledby="planets-heading">
        <span class="section-tag">🪐 7 worlds</span>
        <h2 id="planets-heading">The planets</h2>
        <p class="lede">Listed roughly inner-orbit-out. Each card mirrors what you'd see if you opened it in the interactive cosmos.</p>

        <ol class="static-planets" role="list">
          {composed.map((p) => (
            <li class="static-planet" id={`planet-${p.slug}`}>
              <div class="static-planet__head">
                <span class="static-planet__icon" aria-hidden="true">
                  <PlanetIcon slug={p.slug as IconSlug} size={48} scope={`static-${p.slug}`} />
                </span>
                <div>
                  <h3>{p.name}</h3>
                  <span class="meta">{p.type} · {p.atmosphere} · {p.status}</span>
                </div>
              </div>

              {p.badge && <span class="static-firewall">{p.badge}</span>}

              <p class="static-planet__tagline">{p.tagline}</p>

              {p.stats && p.stats.length > 0 && (
                <ul class="static-stats" role="list">
                  {p.stats.map((s) => (<li>{s}</li>))}
                </ul>
              )}

              <div class="static-planet__body">
                <div>
                  <span class="label">Who it's for</span>
                  <p>{p.audience}</p>
                </div>
                <div>
                  <span class="label">What you'll find</span>
                  <p>{p.content}</p>
                </div>
                <div>
                  <span class="label">Founder note</span>
                  <p class="founder">"{p.founder}"</p>
                </div>
              </div>

              <a class="static-planet__visit" href={p.url} rel="noopener">Visit {p.name}</a>

              {p.moons && p.moons.length > 0 && (
                <div class="static-moons">
                  <p class="static-moons-label">Moons</p>
                  {p.moons.map((m) => (
                    <article class="static-moon" id={`moon-${m.slug}`}>
                      <div class="static-moon__head">
                        <span class="static-moon__icon" aria-hidden="true">
                          <PlanetIcon slug={m.slug as IconSlug} size={28} scope={`static-${m.slug}`} />
                        </span>
                        <div>
                          <h4>{m.name}</h4>
                          <span class="meta">{m.type} · {m.atmosphere} · {m.status}</span>
                        </div>
                      </div>
                      {m.badge && <span class="static-firewall">{m.badge}</span>}
                      <p>{m.tagline}</p>
                      <p>{m.content}</p>
                      <p class="founder">"{m.founder}"</p>
                      {m.stats && m.stats.length > 0 && (
                        <ul class="static-stats static-stats--moon" role="list">
                          {m.stats.map((s) => (<li>{s}</li>))}
                        </ul>
                      )}
                      <a class="visit" href={m.url} rel="noopener">Visit {m.name}</a>
                    </article>
                  ))}
                </div>
              )}
            </li>
          ))}
        </ol>
      </section>

      <section class="static-section static-mcp" aria-labelledby="mcp-heading">
        <div class="static-planet__head">
          <span class="static-planet__icon" aria-hidden="true">
            <PlanetIcon slug="mcp" size={48} scope="static-mcp" />
          </span>
          <div>
            <span class="section-tag">⭐ Star</span>
            <h2 id="mcp-heading">{atlas.mcp.name}</h2>
          </div>
        </div>
        <p class="lede">{atlas.mcp.tagline}. {atlas.mcp.content}</p>

        <div class="static-planet__body">
          <div>
            <span class="label">Who it's for</span>
            <p>{atlas.mcp.audience}</p>
          </div>
          <div>
            <span class="label">Founder note</span>
            <p class="founder">"{atlas.mcp.founder}"</p>
          </div>
        </div>

        <h3 class="endpoints-heading">Per-planet endpoints</h3>
        <ul class="static-mcp-endpoints" role="list">
          {atlas.mcp.endpoints.map((e) => (
            <li>
              <div>
                <span class="name">{e.name}</span>
                {e.url && (<><br><span class="endpoint-url">{e.url}</span></>)}
              </div>
              <span class={e.status === 'live' ? 'status-live' : 'status-planned'}>
                {e.status}
              </span>
            </li>
          ))}
        </ul>
      </section>

      {/* V3.3 — list-view section for external channels (long-form, bites, kofi).
           Same layout as planets so screen-readers and crawlers see them. Each
           ends with the external-link CTAs from atlas.json. */}
      {(atlas.external?.channels ?? []).length > 0 && (
        <section class="static-section static-externals" aria-labelledby="externals-heading">
          <span class="section-tag">📡 External channels</span>
          <h2 id="externals-heading">Outside the cosmos</h2>
          <p class="lede">Three channels that connect the cosmos to the wider world. They sit outside the planet orbits — broadcasts and exchange points, not destinations inside.</p>
          <ol class="static-planets" role="list">
            {(atlas.external?.channels ?? []).map((ch) => (
              <li class="static-planet" id={`external-${ch.slug}`}>
                <div class="static-planet__head">
                  <span class="static-planet__icon" aria-hidden="true">
                    <PlanetIcon slug={ch.slug as IconSlug} size={48} scope={`static-${ch.slug}`} />
                  </span>
                  <div>
                    <h3>{ch.name}</h3>
                    <span class="meta">{ch.type}</span>
                  </div>
                </div>
                <p class="static-planet__tagline">{ch.tagline}</p>
                {ch.stats && ch.stats.length > 0 && (
                  <ul class="static-stats" role="list">
                    {ch.stats.map((s) => (<li>{s}</li>))}
                  </ul>
                )}
                <div class="static-planet__body">
                  <div>
                    <span class="label">Who it's for</span>
                    <p>{ch.audience}</p>
                  </div>
                  <div>
                    <span class="label">What you'll find</span>
                    <p>{ch.content}</p>
                  </div>
                  <div>
                    <span class="label">Founder note</span>
                    <p class="founder">"{ch.founder}"</p>
                  </div>
                </div>
                {(ch as { ctas?: { label: string; icon?: string; url: string }[] }).ctas && ((ch as { ctas?: { label: string; icon?: string; url: string }[] }).ctas ?? []).length > 0 ? (
                  <div class="static-planet__ctas">
                    {((ch as { ctas?: { label: string; icon?: string; url: string }[] }).ctas ?? []).map((c, i) => (
                      <a class={`static-planet__visit ${i === 0 ? '' : 'static-planet__visit--secondary'}`} href={c.url} target="_blank" rel="noopener noreferrer">
                        {c.icon} {c.label}
                      </a>
                    ))}
                  </div>
                ) : (
                  <a class="static-planet__visit" href={ch.url} target="_blank" rel="noopener noreferrer">
                    {(ch as { ctaLabel?: string }).ctaLabel ?? `Open ${ch.name}`} {(ch as { ctaIcon?: string }).ctaIcon ?? '↗'}
                  </a>
                )}
              </li>
            ))}
          </ol>
        </section>
      )}

      <footer class="static-footer">
        <p>
          Pre-build · drafted 8 May 2026 · part of the <a href="https://www.aguidetocloud.com/" rel="noopener">A Guide to Cloud</a> cosmos.
        </p>
      </footer>
    </article>
  </main>

  <script type="application/json" id="cosmos-data" set:html={JSON.stringify(clientData)}></script>
  <script>
    import { mountCosmos } from '../scripts/cosmos.ts';
    const dataEl = document.getElementById('cosmos-data') as HTMLScriptElement | null;
    if (dataEl?.textContent) {
      try {
        const data = JSON.parse(dataEl.textContent);
        mountCosmos(data);
      } catch (err) {
        console.warn('[cosmos] Failed to parse cosmos data; static fallback remains visible.', err);
      }
    }
  </script>
</Base>

